# OS/editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Root env/log/temp
.env
*.log
tmp/
temp/
.cache/

# Root docs/build leftovers
*.tsbuildinfo
dist/
build/
coverage/
out-tsc/
.angular/

# Frontend/backend dependency and build directories (when present under root tracking)
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.angular/
backend/.venv/
backend/__pycache__/
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/

# Prevent nested repo internals from being tracked in root
frontend/.git/
backend/.git/

# Nested repository lockfiles should be managed inside their own repos
frontend/package-lock.json
frontend/yarn.lock
frontend/pnpm-lock.yaml
backend/uv.lock
